<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;1,300&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="../stylesheets/base.css" />
    <title>Cart page</title>
  </head>
  <body>
    <% if(alert.length>0){%>
    <div id="flash-alert"
      class="absolute left-1\2 w-full -translate-x-1\2 -translate-y-1\2 p-3 rounded-md flex justify-center"
    >
      <span
        class="inline-block mt-1 w-80 mb-1 text-black font-extralight center bg-[#fff3cd] rounded-md p-3"
      >
        <%=alert[0]%>
      </span>
    </div>
    <%}%>
    <div class="h-screen w-full bg-[#ebecf0] font-roboto font-light text-black">
      <div
        class="h-18 text-black flex justify-between pt-5 bg-[#bae6e5] px-10 text-lg"
      >
        <div><h1 class="font-bold">Scatch.</h1></div>
        <div class="mx-3">
          <a
            href="/product/home"
            class="mx-2 hover:font-bold hover:text-[#35363b]"
            >Home</a
          >
          <a href="#" class="mx-2 hover:font-bold hover:text-[#35363b]"
            >My account</a
          >
        </div>
      </div>
      <div class="flex flex-col items-center">
          <%user.cart.forEach((val)=>{%>
            <%grandTotal=grandTotal + val.productPrice - val.discount%>
            <div class="h-18 w-8/10 rounded-xl bg-zinc-500 mt-6 flex">
              <div class="h-11 w-10 rounded mt-3 ml-4 overflow-hidden">
                <a href="/product/bag/<%=val._id%>"><img 
                  src="data:<%= val.contentType %>;base64,<%= val.productImage.toString('base64') %>" 
                  alt="product image" 
                  class="w-full h-full object-cover rounded"
                /></a>
              </div>
              <div class="mt-2 ml-10 w-8/10 font-extralight text-lg">
                <h1>Product Name : <%=val.productName%> </h1>
                <h1>Proudct Price : &#8377 <%=val.productPrice - val.discount%></h1>
              </div>
              <div class="mt-6 ml-5">
                <a href="/product/cart/remove/<%=val._id%>"
                  ><i
                    class="fa-regular fa-trash-can fa-xl"
                    style="color: rgb(196, 28, 28)"
                  ></i
                ></a>
              </div>
            </div>
          <%})%>
      </div>
      <div class="h-18 w-full bg-green-500 absolute bottom-0 rounded-t-2xl">
        <div class=" flex justify-between">
          <h1 class="text-xl mt-5 ml-10">Grand Total : &#8377 <%=grandTotal%> </h1>
          <a href="/product/payment" class="text-xl mt-5 mr-10 bg-zinc-500 px-5 py-1 rounded-xl">&#8377 &#8377 Pay now&#8377 &#8377 </a>
        </div>
      </div>
    </div>
    <script>
  // Auto-hide after 5 seconds
    setTimeout(function() {
      const alert = document.getElementById("flash-alert");
      if (alert) {
        alert.style.transition = "opacity 0.5s ease"; // smooth fade
        alert.style.opacity = "0";
        setTimeout(() => alert.remove(), 500); // remove from DOM after fade
      }
    }, 1000);
  </script>
  </body>
</html>
